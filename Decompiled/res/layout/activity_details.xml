<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@id/IV_MainBackground"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:src="@drawable/crowd"
        android:scaleType="fitXY" />
    <TextView
        android:background="@drawable/bg_gradient_trans"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/btnSongList"
        android:background="?selectableItemBackground"
        android:layout_width="wrap_content"
        android:layout_height="?actionBarSize"
        android:layout_marginRight="20.0dip"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true">
        <ImageView
            android:background="?selectableItemBackground"
            android:padding="6.0dip"
            android:layout_width="?actionBarSize"
            android:layout_height="?actionBarSize"
            app:srcCompat="@drawable/ic_round_keyboard_arrow_left_24"
            app:tint="@android:color/white" />
        <TextView
            android:textAppearance="@style/TextAppearance.FontPath.Bold"
            android:textSize="18.0dip"
            android:textColor="@android:color/white"
            android:layout_gravity="center"
            android:id="@id/txtSongText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="16.0dip"
            android:text="Song Details" />
    </LinearLayout>
    <com.google.android.gms.ads.AdView
        android:id="@id/adView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        app:adSize="BANNER"
        app:adUnitId="@string/banner_ad_unit_id" />
    <ScrollView
        android:padding="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/adView"
        android:layout_below="@id/btnSongList">
        <RelativeLayout
            android:layout_gravity="center"
            android:background="@android:color/white"
            android:padding="10.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/lay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/bandImg"
                    android:layout_width="150.0dip"
                    android:layout_height="wrap_content"
                    android:src="@drawable/crowd"
                    android:adjustViewBounds="true" />
                <TableLayout
                    android:id="@id/tabLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16.0dip"
                    android:layout_toRightOf="@id/lay"
                    android:layout_centerVertical="true">
                    <TableRow>
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="16.0sp"
                            android:textColor="@android:color/black"
                            android:text="Nama Band/Penyanyi" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                            android:textSize="16.0sp"
                            android:textColor="@android:color/black"
                            android:id="@id/TV_Band"
                            android:layout_marginLeft="20.0dip"
                            android:text="" />
                    </TableRow>
                    <TableRow
                        android:layout_marginTop="6.0dip">
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="16.0sp"
                            android:textColor="@android:color/black"
                            android:text="Judul Lagu" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                            android:textSize="16.0sp"
                            android:textColor="@android:color/black"
                            android:id="@id/TV_Judul"
                            android:layout_marginLeft="20.0dip"
                            android:text="" />
                    </TableRow>
                    <TableRow
                        android:layout_marginTop="20.0dip">
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="16.0sp"
                            android:textColor="@android:color/black"
                            android:text="Note Creator" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                            android:textSize="16.0sp"
                            android:textColor="@android:color/holo_blue_dark"
                            android:id="@id/TV_Creator"
                            android:background="?selectableItemBackground"
                            android:layout_marginLeft="20.0dip"
                            android:text="ihsan_bz"
                            android:drawableLeft="@drawable/about_icon_instagram_sm"
                            android:drawablePadding="10.0dip"
                            android:drawableTint="@android:color/holo_blue_dark" />
                    </TableRow>
                    <TableRow
                        android:layout_marginTop="6.0dip">
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="16.0sp"
                            android:textColor="@android:color/black"
                            android:text="Jumlah Note" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                            android:textSize="16.0sp"
                            android:textColor="@android:color/black"
                            android:id="@id/TV_NoteCount"
                            android:layout_marginLeft="20.0dip"
                            android:text="0" />
                    </TableRow>
                </TableLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16.0dip"
                android:layout_below="@id/lay"
                android:layout_centerHorizontal="true">
                <Button
                    android:textSize="12.0dip"
                    android:textColor="@color/about_instagram_color"
                    android:layout_gravity="center"
                    android:id="@id/txtNoteCreator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10.0dip"
                    android:text="Instagram"
                    android:drawableLeft="@drawable/about_icon_instagram_sm"
                    android:drawablePadding="10.0dip"
                    android:textAllCaps="false"
                    android:drawableTint="@color/about_instagram_color"
                    style="@style/Widget.AppCompat.Button.Borderless" />
                <Button
                    android:textSize="12.0dip"
                    android:textColor="@color/about_github_color"
                    android:layout_gravity="center"
                    android:id="@id/txtNoteCreatorTiktok"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10.0dip"
                    android:text="Tiktok"
                    android:drawableLeft="@drawable/icons8_tiktok_sm"
                    android:drawablePadding="10.0dip"
                    android:textAllCaps="false"
                    android:drawableTint="@color/about_github_color"
                    style="@style/Widget.AppCompat.Button.Borderless" />
            </LinearLayout>
        </RelativeLayout>
    </ScrollView>
</RelativeLayout>