<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <androidx.recyclerview.widget.RecyclerView
        android:id="@id/RV_List"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:fillViewport="true"
        android:layout_above="@id/layInfo" />
    <TextView
        android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
        android:textSize="20.0dip"
        android:id="@id/TV_Empty"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16.0dip"
        android:text="Belum Ada Lagu"
        android:layout_centerHorizontal="true" />
    <RelativeLayout
        android:id="@id/layInfo"
        android:background="@color/bg_info"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <TextView
            android:textSize="12.0dip"
            android:textStyle="italic"
            android:id="@id/txtFolderInfo"
            android:padding="6.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Folder Penyimpanan : " />
        <TextView
            android:textAppearance="@style/TextAppearance.FontPath.Bold"
            android:textSize="12.0dip"
            android:textColor="#ff0022ff"
            android:gravity="center"
            android:id="@id/txtFolderInfoClick"
            android:background="?selectableItemBackground"
            android:padding="6.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:text="LIHAT INFO"
            android:drawableRight="@drawable/ic_baseline_arrow_forward_16"
            android:drawablePadding="4.0dip"
            android:layout_alignParentRight="true"
            android:drawableTint="#ff0022ff" />
    </RelativeLayout>
</RelativeLayout>