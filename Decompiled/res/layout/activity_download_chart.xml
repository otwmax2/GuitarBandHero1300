<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:background="@drawable/backgroundimage"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/crowd_bottom"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        android:layout_alignParentBottom="true" />
    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:theme="@style/ActionBarThemeOverlay2"
            android:id="@id/toolbar"
            android:background="@android:color/transparent"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="?actionBarSize"
            android:minHeight="?actionBarSize"
            app:titleTextAppearance="@style/TextAppearance.FontPath.Actionbar.Title" />
    </RelativeLayout>
    <RelativeLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/bg_import_card"
        android:padding="8.0dip"
        android:layout_width="550.0dip"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <ImageButton
            android:id="@id/btnBack"
            android:background="@drawable/bg_cancel_btn"
            android:padding="8.0dip"
            android:layout_width="wrap_content"
            android:layout_height="32.0dip"
            android:src="@drawable/ic_back"
            app:tint="#ffffffff" />
        <LinearLayout
            android:orientation="vertical"
            android:paddingTop="16.0dip"
            android:paddingBottom="16.0dip"
            android:layout_width="550.0dip"
            android:layout_height="wrap_content"
            android:paddingVertical="16.0dip">
            <androidx.cardview.widget.CardView
                android:layout_gravity="center"
                android:id="@id/cardImgThumbnail"
                android:layout_width="80.0dip"
                android:layout_height="80.0dip"
                app:cardCornerRadius="6.0dip"
                app:cardElevation="16.0dip"
                app:cardMaxElevation="16.0dip">
                <ImageView
                    android:id="@id/imgThumbnail"
                    android:layout_width="80.0dip"
                    android:layout_height="80.0dip"
                    android:src="@drawable/placeholder_img"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:contentDescription="@null" />
            </androidx.cardview.widget.CardView>
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                android:textSize="14.0sp"
                android:textColor="#ffffffff"
                android:layout_gravity="center"
                android:id="@id/txtjudul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4.0dip"
                android:text="Judul Lagu" />
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                android:textSize="12.0sp"
                android:textColor="#ff9e66ff"
                android:layout_gravity="center"
                android:id="@id/txtband"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Band" />
            <RelativeLayout
                android:id="@id/rvDetail"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true">
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true">
                    <TextView
                        android:textAppearance="@style/TextAppearance.FontPath.Regular"
                        android:textStyle="italic"
                        android:textColor="#ffffffff"
                        android:id="@id/txtStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8.0dip"
                        android:text="DOWNLOADING..."
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true" />
                    <RelativeLayout
                        android:layout_width="450.0dip"
                        android:layout_height="wrap_content">
                        <ProgressBar
                            android:id="@id/progressBar"
                            android:layout_width="fill_parent"
                            android:layout_height="10.0dip"
                            android:layout_marginTop="10.0dip"
                            android:layout_marginRight="10.0dip"
                            android:max="100"
                            android:progress="0"
                            android:indeterminate="false"
                            android:progressDrawable="@drawable/progress_bar_gradient"
                            android:layout_toLeftOf="@id/txtPersent"
                            android:layout_centerVertical="true"
                            style="@style/ProgressBarPrimary" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textColor="#ffffffff"
                            android:id="@id/txtPersent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100%"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true" />
                    </RelativeLayout>
                    <RelativeLayout
                        android:id="@id/layAd"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8.0dip">
                        <RelativeLayout
                            android:id="@id/templateAd"
                            android:background="@android:color/white"
                            android:visibility="gone"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:id="@id/imgIklan"
                                android:layout_width="280.0dip"
                                android:layout_height="50.0dip"
                                android:src="@drawable/iklan"
                                android:scaleType="fitStart"
                                android:adjustViewBounds="true" />
                            <ImageView
                                android:padding="2.0dip"
                                android:layout_width="100.0dip"
                                android:layout_height="50.0dip"
                                android:src="@drawable/google_play"
                                android:layout_toRightOf="@id/imgIklan" />
                            <ImageView
                                android:id="@id/imgBerlangganan"
                                android:padding="2.0dip"
                                android:layout_width="200.0dip"
                                android:layout_height="50.0dip"
                                android:src="@drawable/berlangganan"
                                android:adjustViewBounds="true"
                                android:layout_alignParentRight="true"
                                android:layout_centerVertical="true" />
                        </RelativeLayout>
                        <com.google.android.gms.ads.AdView
                            android:id="@id/adView"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            app:adSize="BANNER"
                            app:adUnitId="@string/banner_ad_unit_id" />
                    </RelativeLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@id/layoutButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <Button
                            android:enabled="false"
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textSize="14.0sp"
                            android:textColor="@android:color/white"
                            android:id="@id/BtnMainkan"
                            android:background="@drawable/bg_button_purple"
                            android:paddingLeft="16.0dip"
                            android:paddingRight="16.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6.0dip"
                            android:layout_marginRight="6.0dip"
                            android:text="PLAY NOW"
                            android:drawablePadding="8.0dip"
                            android:textAllCaps="false"
                            android:drawableTint="#ffffffff"
                            android:paddingHorizontal="16.0dip" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>