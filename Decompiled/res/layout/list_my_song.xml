<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4.0dip"
    app:cardBackgroundColor="#ff19204b"
    app:cardCornerRadius="6.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:id="@id/RL_MainLayout"
        android:background="@drawable/list_gradient"
        android:paddingLeft="16.0dip"
        android:paddingTop="8.0dip"
        android:paddingRight="16.0dip"
        android:paddingBottom="8.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:id="@id/cardImgThumbnail"
            android:layout_width="40.0dip"
            android:layout_height="40.0dip"
            android:layout_centerVertical="true"
            app:cardCornerRadius="6.0dip">
            <ImageView
                android:id="@id/imgThumbnail"
                android:layout_width="40.0dip"
                android:layout_height="40.0dip"
                android:src="@drawable/placeholder_img"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true" />
        </androidx.cardview.widget.CardView>
        <RelativeLayout
            android:id="@id/linear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_toRightOf="@id/cardImgThumbnail"
            android:layout_centerVertical="true">
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                android:textColor="#ffffffff"
                android:id="@id/TV_Judul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seven Nation Army" />
        </RelativeLayout>
        <Button
            android:theme="@style/MyButton"
            android:textAppearance="@style/TextAppearance.FontPath.Bold"
            android:textSize="16.0sp"
            android:textColor="@android:color/white"
            android:id="@id/BtnPlay"
            android:background="@drawable/bg_button_purple"
            android:paddingLeft="8.0dip"
            android:paddingRight="8.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Play"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:textAllCaps="false"
            android:paddingHorizontal="8.0dip" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>