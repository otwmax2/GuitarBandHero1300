<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:background="@drawable/backgroundimage"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:id="@id/topBar"
        android:paddingLeft="12.0dip"
        android:paddingTop="12.0dip"
        android:paddingRight="12.0dip"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <Button
            android:textAppearance="@style/TextAppearance.FontPath.Bold"
            android:textSize="11.0sp"
            android:textColor="#ffffffff"
            android:id="@id/btnSongList"
            android:background="@drawable/bg_cancel_btn"
            android:layout_width="wrap_content"
            android:layout_height="32.0dip"
            android:text="BACK"
            android:drawableLeft="@drawable/ic_back"
            android:drawablePadding="8.0dip"
            android:textAllCaps="true"
            android:paddingStart="12.0dip"
            android:paddingEnd="16.0dip"
            android:drawableTint="#ffffffff" />
    </RelativeLayout>
    <com.google.android.gms.ads.AdView
        android:id="@id/adView"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        app:adSize="SMART_BANNER"
        app:adUnitId="@string/banner_ad_unit_id" />
    <RelativeLayout
        android:padding="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_above="@id/adView">
        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true">
            <TableLayout
                android:id="@id/table"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24.0dip"
                android:layout_marginRight="24.0dip"
                android:stretchColumns="0">
                <TableRow>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_marginLeft="24.0dip">
                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="6.0dip"
                            app:cardElevation="16.0dip"
                            app:cardMaxElevation="16.0dip">
                            <ImageView
                                android:id="@id/imgThumbnail"
                                android:layout_width="120.0dip"
                                android:layout_height="120.0dip"
                                android:src="@drawable/placeholder_img"
                                android:scaleType="centerCrop"
                                android:adjustViewBounds="true" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout
                            android:layout_gravity="center_vertical"
                            android:orientation="vertical"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="16.0dip">
                            <TextView
                                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                                android:textSize="14.0sp"
                                android:textColor="@android:color/white"
                                android:layout_gravity="center"
                                android:id="@id/txtSongText"
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:text="Judul Lagu" />
                            <TextView
                                android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                                android:textColor="@android:color/darker_gray"
                                android:layout_gravity="center"
                                android:id="@id/txtBandText"
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:text="Judul Lagu" />
                            <TextView
                                android:textAppearance="@style/TextAppearance.FontPath.Regular"
                                android:textStyle="italic"
                                android:textColor="#ffffffff"
                                android:id="@id/txtMode"
                                android:background="@drawable/radial_gradient_expert"
                                android:paddingLeft="16.0dip"
                                android:paddingTop="4.0dip"
                                android:paddingRight="16.0dip"
                                android:paddingBottom="4.0dip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16.0dip"
                                android:text="EXPERT" />
                            <RelativeLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">
                                <RatingBar
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="-60.0dip"
                                    android:progress="100"
                                    android:scaleX="0.5"
                                    android:scaleY="0.5" />
                                <RatingBar
                                    android:id="@id/RatingBar"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="-60.0dip"
                                    android:scaleX="0.5"
                                    android:scaleY="0.5"
                                    android:progressTint="@color/colorAccent2" />
                            </RelativeLayout>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_marginRight="24.0dip">
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@id/imgScore"
                            android:layout_width="80.0dip"
                            android:layout_height="80.0dip"
                            app:srcCompat="@drawable/award_symbol"
                            app:tint="#ffffffff" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textSize="30.0sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:layout_gravity="center"
                            android:id="@id/TV_Score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="123,456" />
                    </LinearLayout>
                </TableRow>
            </TableLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="48.0dip"
                android:layout_marginRight="48.0dip"
                android:layout_below="@id/table"
                android:layout_marginHorizontal="48.0dip">
                <TableLayout
                    android:layout_gravity="center"
                    android:background="@drawable/bg_import_card"
                    android:paddingLeft="16.0dip"
                    android:paddingTop="4.0dip"
                    android:paddingRight="16.0dip"
                    android:paddingBottom="4.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="0,1,2">
                    <TableRow>
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                            android:textSize="12.0sp"
                            android:textColor="@android:color/white"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOTE HIT"
                            android:drawablePadding="10.0dip"
                            android:drawableTint="@android:color/white" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                            android:textSize="12.0sp"
                            android:textColor="@android:color/white"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOTE MISS"
                            android:drawablePadding="10.0dip"
                            android:drawableTint="@android:color/white" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                            android:textSize="12.0sp"
                            android:textColor="@android:color/white"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MAX STREAK"
                            android:drawablePadding="10.0dip"
                            android:drawableTint="@android:color/white" />
                    </TableRow>
                    <TableRow
                        android:layout_marginTop="6.0dip">
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textSize="14.0sp"
                            android:textColor="@android:color/white"
                            android:gravity="center"
                            android:id="@id/txtNoteHit"
                            android:layout_height="wrap_content"
                            android:text="0" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textSize="14.0sp"
                            android:textColor="@android:color/white"
                            android:gravity="center"
                            android:id="@id/txtNoteMiss"
                            android:layout_height="wrap_content"
                            android:text="0" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textSize="14.0sp"
                            android:textColor="@android:color/white"
                            android:gravity="center"
                            android:id="@id/txtMaxStreak"
                            android:layout_height="wrap_content"
                            android:text="0" />
                    </TableRow>
                </TableLayout>
                <TableLayout
                    android:layout_gravity="center"
                    android:background="@drawable/bg_import_card"
                    android:paddingLeft="16.0dip"
                    android:paddingTop="4.0dip"
                    android:paddingRight="16.0dip"
                    android:paddingBottom="4.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="1">
                    <TableRow>
                        <LinearLayout
                            android:orientation="vertical">
                            <TextView
                                android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                                android:textSize="12.0sp"
                                android:textColor="@android:color/white"
                                android:gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACCURACY"
                                android:drawablePadding="10.0dip"
                                android:drawableTint="@android:color/white" />
                            <TextView
                                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                                android:textSize="16.0sp"
                                android:textColor="@android:color/white"
                                android:gravity="center"
                                android:id="@id/txtAccuracy"
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:drawablePadding="10.0dip"
                                android:drawableTint="@android:color/white" />
                        </LinearLayout>
                        <ProgressBar
                            android:layout_gravity="center_vertical"
                            android:id="@id/progressAccuracy"
                            android:layout_width="fill_parent"
                            android:layout_height="10.0dip"
                            android:layout_marginLeft="24.0dip"
                            android:layout_marginRight="24.0dip"
                            android:max="100"
                            android:progress="100"
                            android:indeterminate="false"
                            style="@style/ProgressBarPrimary" />
                    </TableRow>
                </TableLayout>
                <TableLayout
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8.0dip"
                    android:layout_marginBottom="8.0dip">
                    <TableRow>
                        <Button
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textSize="14.0sp"
                            android:textColor="#ffffffff"
                            android:id="@id/Btn_Share"
                            android:background="@drawable/bg_cancel_btn"
                            android:paddingLeft="12.0dip"
                            android:paddingRight="12.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10.0dip"
                            android:layout_marginRight="10.0dip"
                            android:text="SHARE"
                            android:drawableLeft="@drawable/ic_round_share_24"
                            android:drawablePadding="6.0dip"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:textAllCaps="false"
                            android:drawableTint="#ffffffff" />
                        <Button
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textSize="14.0sp"
                            android:textColor="#ffffffff"
                            android:id="@id/Btn_Replay"
                            android:background="@drawable/bg_cancel_btn"
                            android:paddingLeft="12.0dip"
                            android:paddingRight="12.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10.0dip"
                            android:layout_marginRight="10.0dip"
                            android:text="REPLAY"
                            android:drawableLeft="@drawable/ic_round_reload"
                            android:drawablePadding="6.0dip"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:textAllCaps="false"
                            android:drawableTint="#ffffffff" />
                        <Button
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textSize="14.0sp"
                            android:textColor="#ffffffff"
                            android:id="@id/Btn_Songlist"
                            android:background="@drawable/bg_button_purple"
                            android:paddingLeft="12.0dip"
                            android:paddingRight="12.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10.0dip"
                            android:layout_marginRight="10.0dip"
                            android:text="SONG LIST"
                            android:drawableLeft="@drawable/ic_list_bulleted_24"
                            android:drawablePadding="6.0dip"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:textAllCaps="false"
                            android:drawableTint="#ffffffff" />
                    </TableRow>
                </TableLayout>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>