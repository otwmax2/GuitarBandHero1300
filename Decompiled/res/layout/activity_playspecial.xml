<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:background="@android:color/white"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@id/IV_MainBackground"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:src="@drawable/crowd"
            android:scaleType="fitXY" />
        <androidx.appcompat.widget.Toolbar
            android:theme="@style/ActionBarThemeOverlay2"
            android:id="@id/toolbar"
            android:background="@android:color/transparent"
            android:layout_width="fill_parent"
            android:layout_height="?actionBarSize"
            android:minHeight="?actionBarSize"
            app:titleTextAppearance="@style/TextAppearance.FontPath.Actionbar.Title" />
    </RelativeLayout>
    <androidx.cardview.widget.CardView
        android:orientation="vertical"
        android:background="#8fffffff"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginLeft="16.0dip"
        android:layout_marginTop="?actionBarSize"
        android:layout_marginRight="16.0dip"
        android:layout_marginBottom="16.0dip"
        app:cardBackgroundColor="#8fffffff"
        app:cardCornerRadius="0.0dip">
        <TableLayout
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="0">
            <TableRow
                android:layout_width="fill_parent">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                        android:textSize="20.0dip"
                        android:layout_gravity="center"
                        android:id="@id/txtjudul"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Band - Judul Lagu" />
                    <RelativeLayout
                        android:id="@id/rvDetail"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true">
                        <LinearLayout
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingTop="16.0dip"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true">
                            <com.google.android.gms.ads.AdView
                                android:id="@id/adView"
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                app:adSize="BANNER"
                                app:adUnitId="@string/banner_ad_unit_id" />
                            <LinearLayout
                                android:orientation="vertical"
                                android:id="@id/layoutButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">
                                <Button
                                    android:theme="@style/MyButton"
                                    android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                                    android:textSize="14.0dip"
                                    android:textColor="@android:color/white"
                                    android:layout_gravity="center"
                                    android:id="@id/BtnDownload"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Main Tanpa Spesial"
                                    android:textAllCaps="false" />
                                <Button
                                    android:theme="@style/MyButton3"
                                    android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                                    android:textSize="20.0dip"
                                    android:textColor="@android:color/white"
                                    android:layout_gravity="center"
                                    android:id="@id/BtnPlaySpec"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Main Dengan Spesial"
                                    android:drawableRight="@drawable/icon_ads"
                                    android:drawablePadding="10.0dip"
                                    android:textAllCaps="false"
                                    android:drawableTint="@android:color/white" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_gravity="center"
                                android:orientation="horizontal"
                                android:padding="10.0dip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10.0dip">
                                <Button
                                    android:theme="@style/MyButton2"
                                    android:textSize="12.0dip"
                                    android:textColor="@color/about_instagram_color"
                                    android:layout_gravity="center"
                                    android:id="@id/txtNoteCreator"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="10.0dip"
                                    android:text="Instagram"
                                    android:drawableLeft="@drawable/about_icon_instagram_sm"
                                    android:drawablePadding="10.0dip"
                                    android:textAllCaps="false"
                                    android:drawableTint="@color/about_instagram_color" />
                                <Button
                                    android:theme="@style/MyButton2"
                                    android:textSize="12.0dip"
                                    android:textColor="@color/about_github_color"
                                    android:layout_gravity="center"
                                    android:id="@id/txtNoteCreatorTiktok"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="10.0dip"
                                    android:text="Tiktok"
                                    android:drawableLeft="@drawable/icons8_tiktok_sm"
                                    android:drawablePadding="10.0dip"
                                    android:textAllCaps="false"
                                    android:drawableTint="@color/about_github_color" />
                            </LinearLayout>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/mainLayout"
                    android:background="@color/bg_info"
                    android:padding="10.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="6.0dip">
                    <RelativeLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10.0dip">
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Bold"
                            android:textSize="14.0dip"
                            android:textColor="@color/colorAccent"
                            android:id="@id/dialogTitle"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:text="Pengaturan Notes" />
                    </RelativeLayout>
                    <RelativeLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="6.0dip"
                            android:layout_toLeftOf="@id/btnDefault">
                            <EditText
                                android:id="@id/editTextDelay"
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:hint="Delay (Detik)"
                                android:inputType="numberDecimal" />
                        </com.google.android.material.textfield.TextInputLayout>
                        <Button
                            android:id="@id/btnDefault"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16.0dip"
                            android:text="Default"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:textAllCaps="false" />
                    </RelativeLayout>
                    <TextView
                        android:background="@color/about_description_color"
                        android:layout_width="fill_parent"
                        android:layout_height="0.5dip" />
                    <RelativeLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
                        <CheckBox
                            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                            android:id="@id/checkMirror"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:text="Gunakan Notes Terbalik" />
                    </RelativeLayout>
                    <TextView
                        android:background="@color/about_description_color"
                        android:layout_width="fill_parent"
                        android:layout_height="0.5dip" />
                    <LinearLayout
                        android:orientation="vertical"
                        android:paddingTop="16.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
                        <RelativeLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">
                            <Button
                                android:theme="@style/Widget.MaterialComponents.Button"
                                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                                android:textSize="13.0dip"
                                android:textColor="@android:color/white"
                                android:id="@id/btnUpload"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Download Ulang"
                                android:layout_toLeftOf="@id/btnSimpan"
                                android:layout_alignParentLeft="true"
                                android:textAllCaps="false" />
                            <Button
                                android:theme="@style/Widget.MaterialComponents.Button"
                                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                                android:textSize="13.0dip"
                                android:textColor="@android:color/white"
                                android:id="@id/btnSimpan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Simpan"
                                android:layout_alignParentRight="true"
                                android:textAllCaps="false" />
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </TableRow>
        </TableLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>