<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:background="@android:color/white"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@id/IV_MainBackground"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:src="@drawable/crowd"
            android:scaleType="fitXY" />
        <androidx.appcompat.widget.Toolbar
            android:theme="@style/ActionBarThemeOverlay2"
            android:id="@id/toolbar"
            android:background="@android:color/transparent"
            android:layout_width="fill_parent"
            android:layout_height="?actionBarSize"
            android:minHeight="?actionBarSize"
            app:titleTextAppearance="@style/TextAppearance.FontPath.Actionbar.Title" />
    </RelativeLayout>
    <androidx.cardview.widget.CardView
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginLeft="50.0dip"
        android:layout_marginTop="?actionBarSize"
        android:layout_marginRight="50.0dip"
        android:layout_marginBottom="?actionBarSize"
        app:cardBackgroundColor="#8fffffff"
        app:cardCornerRadius="0.0dip">
        <LinearLayout
            android:orientation="horizontal"
            android:padding="16.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                    android:textSize="20.0dip"
                    android:layout_gravity="center"
                    android:id="@id/txtjudul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Band - Judul Lagu" />
                <RelativeLayout
                    android:id="@id/rvDetail"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true">
                    <LinearLayout
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true">
                        <RelativeLayout
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6.0dip">
                            <ProgressBar
                                android:id="@id/progressBar"
                                android:layout_width="fill_parent"
                                android:layout_height="10.0dip"
                                android:layout_marginTop="10.0dip"
                                android:layout_marginRight="10.0dip"
                                android:max="100"
                                android:progress="0"
                                android:indeterminate="false"
                                android:layout_toLeftOf="@id/txtPersent"
                                android:layout_centerVertical="true"
                                style="@style/ProgressBarPrimary" />
                            <TextView
                                android:textAppearance="@style/TextAppearance.FontPath.Regular"
                                android:id="@id/txtPersent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100%"
                                android:layout_alignParentRight="true"
                                android:layout_centerVertical="true" />
                        </RelativeLayout>
                        <com.google.android.gms.ads.AdView
                            android:id="@id/adView"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            app:adSize="BANNER"
                            app:adUnitId="@string/banner_ad_unit_id" />
                        <LinearLayout
                            android:orientation="horizontal"
                            android:id="@id/layoutButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <Button
                                android:theme="@style/MyButton"
                                android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                                android:textSize="18.0dip"
                                android:textColor="@android:color/white"
                                android:layout_gravity="center"
                                android:id="@id/BtnDownload"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6.0dip"
                                android:layout_marginRight="5.0dip"
                                android:text="Main Tanpa Spesial"
                                android:textAllCaps="false" />
                            <Button
                                android:theme="@style/MyButton3"
                                android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                                android:textSize="20.0dip"
                                android:textColor="@android:color/white"
                                android:layout_gravity="center"
                                android:id="@id/BtnPlaySpec"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="5.0dip"
                                android:layout_marginTop="6.0dip"
                                android:text="Main Dengan Spesial"
                                android:drawableRight="@drawable/icon_ads"
                                android:drawablePadding="10.0dip"
                                android:textAllCaps="false"
                                android:drawableTint="@android:color/white" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:padding="10.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10.0dip">
                            <Button
                                android:theme="@style/MyButton2"
                                android:textSize="12.0dip"
                                android:textColor="@color/about_instagram_color"
                                android:layout_gravity="center"
                                android:id="@id/txtNoteCreator"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10.0dip"
                                android:text="Instagram"
                                android:drawableLeft="@drawable/about_icon_instagram_sm"
                                android:drawablePadding="10.0dip"
                                android:textAllCaps="false"
                                android:drawableTint="@color/about_instagram_color" />
                            <Button
                                android:theme="@style/MyButton2"
                                android:textSize="12.0dip"
                                android:textColor="@color/about_github_color"
                                android:layout_gravity="center"
                                android:id="@id/txtNoteCreatorTiktok"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10.0dip"
                                android:text="Tiktok"
                                android:drawableLeft="@drawable/icons8_tiktok_sm"
                                android:drawablePadding="10.0dip"
                                android:textAllCaps="false"
                                android:drawableTint="@color/about_github_color" />
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>