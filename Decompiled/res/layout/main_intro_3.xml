<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/backgroundimage"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:background="#b0000000"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <RelativeLayout
        android:id="@id/iconContainer"
        android:layout_width="100.0dip"
        android:layout_height="100.0dip"
        android:layout_marginTop="64.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_width="50.0dip"
            android:layout_height="50.0dip"
            android:src="@drawable/ic_folder"
            android:layout_centerInParent="true" />
    </RelativeLayout>
    <TextView
        android:textAppearance="@style/TextAppearance.FontPath.Bold"
        android:textSize="18.0sp"
        android:textStyle="bold"
        android:textColor="#ffffffff"
        android:id="@id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32.0dip"
        android:text="PERMOHONAN AKSES PENYIMPANAN"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconContainer" />
    <TextView
        android:textAppearance="@style/TextAppearance.FontPath.Regular"
        android:textSize="14.0sp"
        android:textColor="#ffcccccc"
        android:gravity="center"
        android:id="@id/textView3"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="16.0dip"
        android:text="Game ini membutuhkan akses ke penyimpanan untuk memuat data, menyimpan progres, dan mengoptimalkan pengalaman bermain kamu."
        android:layout_marginStart="48.0dip"
        android:layout_marginEnd="48.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView2" />
</androidx.constraintlayout.widget.ConstraintLayout>