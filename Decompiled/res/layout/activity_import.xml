<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:background="@drawable/backgroundimage"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:background="#99000000"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <androidx.appcompat.widget.Toolbar
        android:id="@id/toolbar"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="?actionBarSize" />
    <RelativeLayout
        android:id="@id/topBar"
        android:padding="12.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <Button
            android:textAppearance="@style/TextAppearance.FontPath.Bold"
            android:textSize="11.0sp"
            android:textColor="#ffffffff"
            android:id="@id/btnBack"
            android:background="@drawable/bg_cancel_btn"
            android:layout_width="wrap_content"
            android:layout_height="32.0dip"
            android:text="BACK"
            android:drawableLeft="@drawable/ic_back"
            android:drawablePadding="8.0dip"
            android:textAllCaps="true"
            android:paddingStart="12.0dip"
            android:paddingEnd="16.0dip"
            android:drawableTint="#ffffffff" />
        <ImageButton
            android:id="@id/btnHelp"
            android:background="@drawable/bg_cancel_btn"
            android:padding="6.0dip"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip"
            android:src="@drawable/ic_round_help_24"
            android:scaleType="fitCenter"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            app:tint="#ffffffff" />
        <Button
            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
            android:textSize="11.0sp"
            android:textColor="#ffffffff"
            android:id="@id/btnDownload"
            android:background="@drawable/bg_cancel_btn"
            android:paddingLeft="16.0dip"
            android:paddingRight="16.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="8.0dip"
            android:minHeight="0.0dip"
            android:text="Link Download File ZIP"
            android:drawableRight="@drawable/icon_ads"
            android:drawablePadding="6.0dip"
            android:layout_toLeftOf="@id/btnHelp"
            android:layout_centerVertical="true"
            android:textAllCaps="false"
            android:drawableTint="#ffffffff" />
    </RelativeLayout>
    <com.google.android.gms.ads.AdView
        android:id="@id/adView"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:adSize="SMART_BANNER"
        app:adUnitId="@string/banner_ad_unit_id" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/infoBox"
        android:background="@drawable/bg_info_box"
        android:padding="6.0dip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="100.0dip"
        android:layout_marginRight="100.0dip"
        android:layout_marginBottom="4.0dip"
        android:layout_above="@id/adView"
        android:layout_centerHorizontal="true">
        <ImageView
            android:layout_width="18.0dip"
            android:layout_height="18.0dip"
            android:src="@drawable/ic_round_help_24"
            app:tint="#ff7b61ff" />
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8.0dip">
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                android:textSize="9.0sp"
                android:textColor="#ff7b61ff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUPPORTED FORMAT" />
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.Regular"
                android:textSize="8.0sp"
                android:textColor="#ffbbbbbb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=".zip file only. Audio file (mp3/ogg) and chart file (.mid, .chart, .json) must be included in the ZIP." />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@id/contentArea"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="80.0dip"
        android:layout_marginRight="80.0dip"
        android:layout_above="@id/infoBox"
        android:layout_below="@id/topBar"
        android:layout_centerInParent="true">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:background="@drawable/bg_import_card"
            android:padding="12.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="32.0dip"
                android:layout_height="32.0dip"
                android:src="@drawable/baseline_folder_zip_24"
                app:tint="#ff7b61ff" />
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                android:textSize="12.0sp"
                android:textColor="#ffffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4.0dip"
                android:text="Select a ZIP file to import your custom song." />
            <RelativeLayout
                android:id="@id/rvDetail"
                android:background="@drawable/bg_browse_dashed"
                android:padding="8.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8.0dip">
                <ImageView
                    android:id="@id/icFolder"
                    android:layout_width="24.0dip"
                    android:layout_height="24.0dip"
                    android:src="@drawable/ic_folder"
                    android:layout_centerVertical="true"
                    app:tint="#ff7b61ff" />
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="10.0dip"
                    android:layout_toEndOf="@id/icFolder">
                    <TextView
                        android:textAppearance="@style/TextAppearance.FontPath.Bold"
                        android:textSize="11.0sp"
                        android:textColor="#ffffffff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BROWSE ZIP FILE" />
                    <TextView
                        android:textAppearance="@style/TextAppearance.FontPath.Regular"
                        android:textSize="9.0sp"
                        android:textColor="#ff999999"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to select a file" />
                </LinearLayout>
                <Button
                    android:textAppearance="@style/TextAppearance.FontPath.Bold"
                    android:textSize="10.0sp"
                    android:textColor="#ffffffff"
                    android:id="@id/btnBrowseFile"
                    android:background="@drawable/bg_button_purple"
                    android:paddingLeft="12.0dip"
                    android:paddingRight="12.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="28.0dip"
                    android:text="BROWSE >"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:textAllCaps="false" />
            </RelativeLayout>
        </LinearLayout>
        <RelativeLayout
            android:id="@id/layoutProgress"
            android:background="@drawable/bg_import_card"
            android:padding="10.0dip"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6.0dip">
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                android:textSize="10.0sp"
                android:textColor="#ffa24bd6"
                android:id="@id/txtImportingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMPORTING..." />
            <ProgressBar
                android:id="@id/progressBar"
                android:layout_width="fill_parent"
                android:layout_height="8.0dip"
                android:layout_marginTop="8.0dip"
                android:layout_marginRight="8.0dip"
                android:max="100"
                android:progress="68"
                android:progressDrawable="@drawable/progress_import_custom"
                android:layout_toLeftOf="@id/txtPersent"
                android:layout_below="@id/txtImportingLabel"
                style="@android:style/Widget.ProgressBar.Horizontal" />
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                android:textSize="11.0sp"
                android:textColor="#ffffffff"
                android:gravity="center"
                android:id="@id/txtPersent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-4.0dip"
                android:text="68%"
                android:layout_alignTop="@id/progressBar"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true" />
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                android:textSize="10.0sp"
                android:textColor="#ffffffff"
                android:id="@id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4.0dip"
                android:text=""
                android:layout_below="@id/progressBar" />
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.Regular"
                android:textSize="9.0sp"
                android:textColor="#ff999999"
                android:id="@id/txtStatusSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Extracting files... please wait."
                android:layout_below="@id/txtStatus" />
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>