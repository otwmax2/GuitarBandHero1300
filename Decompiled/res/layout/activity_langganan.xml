<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/backgroundimage"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/leftPanel"
        android:padding="16.0dip"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.3">
        <Button
            android:textAppearance="@style/TextAppearance.FontPath.Bold"
            android:textSize="11.0sp"
            android:textColor="#ffffffff"
            android:id="@id/btnBack"
            android:background="@drawable/bg_cancel_btn"
            android:layout_width="wrap_content"
            android:layout_height="32.0dip"
            android:text="BACK"
            android:drawableLeft="@drawable/ic_back"
            android:drawablePadding="8.0dip"
            android:textAllCaps="true"
            android:paddingStart="12.0dip"
            android:paddingEnd="16.0dip"
            android:drawableTint="#ffffffff" />
        <ImageView
            android:layout_width="100.0dip"
            android:layout_height="100.0dip"
            android:layout_marginTop="20.0dip"
            android:src="@drawable/logo_new" />
        <TextView
            android:textAppearance="@style/TextAppearance.FontPath.Regular"
            android:textSize="16.0sp"
            android:textStyle="bold"
            android:textColor="#ffffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            android:text="GUITAR BAND HERO" />
        <TextView
            android:textAppearance="@style/TextAppearance.FontPath.Bold"
            android:textSize="18.0sp"
            android:textStyle="bold"
            android:textColor="#ffffc107"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRO" />
        <TextView
            android:textAppearance="@style/TextAppearance.FontPath.Regular"
            android:textSize="14.0sp"
            android:textColor="#ffdddddd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            android:text="Unlock Everything.\nBecome The Ultimate Rock Star!" />
        <Space
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:layout_weight="1.0" />
        <androidx.cardview.widget.CardView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#cc000000"
            app:cardCornerRadius="16.0dip">
            <LinearLayout
                android:gravity="center_vertical"
                android:padding="16.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="32.0dip"
                    android:layout_height="32.0dip"
                    android:src="@drawable/pro_icon"
                    app:tint="#ffffc107" />
                <TextView
                    android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                    android:textSize="12.0sp"
                    android:textStyle="bold"
                    android:textColor="#ffffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UNLOCK EVERYTHING"
                    android:layout_marginStart="12.0dip" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
    <androidx.cardview.widget.CardView
        android:id="@id/rightPanel"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_margin="16.0dip"
        app:cardBackgroundColor="#96000000"
        app:cardCornerRadius="20.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/leftPanel"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/bg_round_border"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="200.0dip"
                android:layout_height="fill_parent">
                <TextView
                    android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                    android:textSize="14.0sp"
                    android:textStyle="bold"
                    android:textColor="#ffbb86fc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DONATE" />
                <TextView
                    android:textAppearance="@style/TextAppearance.FontPath.Bold"
                    android:textSize="18.0sp"
                    android:textStyle="bold"
                    android:textColor="#ffffffff"
                    android:id="@id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />
                <TextView
                    android:textAppearance="@style/TextAppearance.FontPath.Regular"
                    android:textSize="14.0sp"
                    android:textColor="#ffcccccc"
                    android:id="@id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />
                <androidx.appcompat.widget.AppCompatButton
                    android:textAppearance="@style/TextAppearance.FontPath.Bold"
                    android:textStyle="bold"
                    android:textColor="#ff000000"
                    android:id="@id/btnSubscribe"
                    android:background="@android:color/holo_orange_light"
                    android:padding="16.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="56.0dip"
                    android:layout_marginTop="32.0dip"
                    android:text="SUBSCRIBE NOW" />
                <TextView
                    android:textAppearance="@style/TextAppearance.FontPath.Regular"
                    android:textColor="#ffcccccc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12.0dip"
                    android:text="Cancel anytime" />
            </LinearLayout>
            <ScrollView
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                android:layout_weight="1.0">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="24.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent">
                    <TextView
                        android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                        android:textSize="14.0sp"
                        android:textStyle="bold"
                        android:textColor="#ffbb86fc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRO BENEFITS" />
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:paddingTop="8.0dip"
                        android:paddingBottom="8.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8.0dip"
                        xmlns:android="http://schemas.android.com/apk/res/android">
                        <ImageView
                            android:layout_width="28.0dip"
                            android:layout_height="28.0dip"
                            android:src="@drawable/ic_round_check_circle_outline_24"
                            app:tint="#ffbb86fc" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="10.0sp"
                            android:textStyle="bold"
                            android:textColor="#ffffffff"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bebas Iklan\n(Nikmati game tanpa gangguan iklan)"
                            android:layout_marginStart="12.0dip" />
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:paddingTop="8.0dip"
                        android:paddingBottom="8.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8.0dip"
                        xmlns:android="http://schemas.android.com/apk/res/android">
                        <ImageView
                            android:layout_width="28.0dip"
                            android:layout_height="28.0dip"
                            android:src="@drawable/ic_round_check_circle_outline_24"
                            app:tint="#ffbb86fc" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="10.0sp"
                            android:textStyle="bold"
                            android:textColor="#ffffffff"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kustomisasi Tampilan Game\n(Atur tampilan sesuai kenyamanan bermain)"
                            android:layout_marginStart="12.0dip" />
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:paddingTop="8.0dip"
                        android:paddingBottom="8.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8.0dip"
                        xmlns:android="http://schemas.android.com/apk/res/android">
                        <ImageView
                            android:layout_width="28.0dip"
                            android:layout_height="28.0dip"
                            android:src="@drawable/ic_round_check_circle_outline_24"
                            app:tint="#ffbb86fc" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="10.0sp"
                            android:textStyle="bold"
                            android:textColor="#ffffffff"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ganti Background\n(Pilih background favoritmu)"
                            android:layout_marginStart="12.0dip" />
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:paddingTop="8.0dip"
                        android:paddingBottom="8.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8.0dip"
                        xmlns:android="http://schemas.android.com/apk/res/android">
                        <ImageView
                            android:layout_width="28.0dip"
                            android:layout_height="28.0dip"
                            android:src="@drawable/ic_round_check_circle_outline_24"
                            app:tint="#ffbb86fc" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="10.0sp"
                            android:textStyle="bold"
                            android:textColor="#ffffffff"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Custom Guitar Board\n(Ubah desain board sesuai selera)"
                            android:layout_marginStart="12.0dip" />
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:paddingTop="8.0dip"
                        android:paddingBottom="8.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8.0dip"
                        xmlns:android="http://schemas.android.com/apk/res/android">
                        <ImageView
                            android:layout_width="28.0dip"
                            android:layout_height="28.0dip"
                            android:src="@drawable/ic_round_check_circle_outline_24"
                            app:tint="#ffbb86fc" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="10.0sp"
                            android:textStyle="bold"
                            android:textColor="#ffffffff"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Atur Kecepatan Note\n(Sesuaikan kecepatan lagu dengan kemampuanmu)"
                            android:layout_marginStart="12.0dip" />
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:paddingTop="8.0dip"
                        android:paddingBottom="8.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8.0dip"
                        xmlns:android="http://schemas.android.com/apk/res/android">
                        <ImageView
                            android:layout_width="28.0dip"
                            android:layout_height="28.0dip"
                            android:src="@drawable/ic_round_check_circle_outline_24"
                            app:tint="#ffbb86fc" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.FontPath.Regular"
                            android:textSize="10.0sp"
                            android:textStyle="bold"
                            android:textColor="#ffffffff"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Membantu pengembangan game ini"
                            android:layout_marginStart="12.0dip" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>