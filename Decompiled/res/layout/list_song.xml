<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2.0dip"
    app:cardBackgroundColor="#ff19204b"
    app:cardCornerRadius="6.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:id="@id/RL_MainLayout"
        android:background="@drawable/list_gradient"
        android:paddingLeft="16.0dip"
        android:paddingTop="8.0dip"
        android:paddingRight="16.0dip"
        android:paddingBottom="8.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:id="@id/cardImgThumbnail"
            android:layout_width="40.0dip"
            android:layout_height="40.0dip"
            android:layout_centerVertical="true"
            app:cardCornerRadius="6.0dip">
            <ImageView
                android:id="@id/imgThumbnail"
                android:layout_width="40.0dip"
                android:layout_height="40.0dip"
                android:src="@drawable/placeholder_img"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true" />
        </androidx.cardview.widget.CardView>
        <RelativeLayout
            android:id="@id/linear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_toRightOf="@id/cardImgThumbnail"
            android:layout_centerVertical="true">
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                android:textSize="10.0sp"
                android:textColor="#ffe0e0e0"
                android:id="@id/TV_Band"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textAllCaps="true" />
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.Regular"
                android:textSize="14.0sp"
                android:textColor="#ffffffff"
                android:id="@id/TV_Judul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_below="@id/TV_Band" />
        </RelativeLayout>
        <TextView
            android:textAppearance="@style/TextAppearance.FontPath.Bold"
            android:textSize="14.0sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@id/TV_Score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="20.0dip"
            android:text="0"
            android:drawableLeft="@drawable/ic_round_star_24"
            android:drawablePadding="6.0dip"
            android:layout_toLeftOf="@id/BtnPlay"
            android:layout_centerVertical="true"
            android:drawableTint="#ffff9800" />
        <Button
            android:textAppearance="@style/TextAppearance.FontPath.Bold"
            android:textSize="14.0sp"
            android:textColor="@android:color/white"
            android:id="@id/BtnPlay"
            android:background="@drawable/bg_button_purple"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Play"
            android:layout_toLeftOf="@id/BtnDownloadUlang"
            android:layout_centerVertical="true"
            android:textAllCaps="true" />
        <ImageView
            android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
            android:id="@id/BtnDownloadUlang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5.0dip"
            android:src="@drawable/baseline_downloading_24"
            android:adjustViewBounds="true"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            app:tint="#ffffffff"
            style="@style/Widget.AppCompat.Button.Borderless" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>