<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="5.0dip"
    app:cardElevation="5.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/mainLayout"
        android:padding="6.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                android:textSize="14.0dip"
                android:textColor="@color/colorAccent"
                android:id="@id/dialogTitle"
                android:padding="10.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="Pengaturan Notes" />
            <ImageView
                android:textAppearance="@style/TextAppearance.FontPath.Bold"
                android:id="@id/btnOutBatal"
                android:paddingLeft="6.0dip"
                android:paddingRight="6.0dip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@id/dialogTitle"
                android:layout_alignBottom="@id/dialogTitle"
                android:layout_alignParentRight="true"
                app:srcCompat="@drawable/ic_baseline_close_24"
                app:tint="@color/colorAccent" />
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.textfield.TextInputLayout
                android:padding="16.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16.0dip"
                android:layout_marginTop="16.0dip"
                android:layout_marginRight="16.0dip"
                android:layout_toLeftOf="@id/btnDefault">
                <EditText
                    android:id="@id/editTextDelay"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:hint="Waktu Delay (Detik)"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>
            <Button
                android:id="@id/btnDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16.0dip"
                android:layout_marginTop="16.0dip"
                android:layout_marginRight="16.0dip"
                android:text="Default"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:textAllCaps="false" />
        </RelativeLayout>
        <TextView
            android:background="@color/about_description_color"
            android:layout_width="fill_parent"
            android:layout_height="0.5dip" />
        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <CheckBox
                android:textAppearance="@style/TextAppearance.FontPath.SemiBold"
                android:id="@id/checkMirror"
                android:padding="16.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16.0dip"
                android:layout_marginRight="16.0dip"
                android:checked="false"
                android:text="Gunakan Notes Terbalik" />
        </RelativeLayout>
        <TextView
            android:background="@color/about_description_color"
            android:layout_width="fill_parent"
            android:layout_height="0.5dip" />
        <LinearLayout
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <Button
                    android:theme="@style/Widget.MaterialComponents.Button"
                    android:textAppearance="@style/TextAppearance.FontPath.Bold"
                    android:textColor="@android:color/white"
                    android:id="@id/btnSimpan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIMPAN"
                    android:layout_alignParentRight="true" />
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>