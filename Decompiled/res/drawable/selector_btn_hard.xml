<?xml version="1.0" encoding="utf-8"?>
<ripple
    android:color="#40ffffff"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <selector>
            <item
                android:state_pressed="true">
                <shape
                    android:shape="rectangle">
                    <gradient
                        android:startColor="#ff5c0913"
                        android:endColor="#ff5c0913"
                        android:angle="90.0"
                        android:type="linear"
                        android:centerColor="#ff300509" />
                    <stroke
                        android:width="4.0dip"
                        android:color="#ffff4d3d" />
                    <corners
                        android:radius="16.0dip" />
                </shape>
            </item>
            <item>
                <shape
                    android:shape="rectangle">
                    <gradient
                        android:startColor="#ff44070e"
                        android:endColor="#ff44070e"
                        android:angle="90.0"
                        android:type="linear"
                        android:centerColor="#ff230407" />
                    <stroke
                        android:width="2.0dip"
                        android:color="#ffe63126" />
                    <corners
                        android:radius="16.0dip" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>