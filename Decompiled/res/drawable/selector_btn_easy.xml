<?xml version="1.0" encoding="utf-8"?>
<ripple
    android:color="#40ffffff"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <selector>
            <item
                android:state_pressed="true">
                <shape
                    android:shape="rectangle">
                    <gradient
                        android:startColor="#ff1a4a1f"
                        android:endColor="#ff1a4a1f"
                        android:angle="90.0"
                        android:type="linear"
                        android:centerColor="#ff023009" />
                    <stroke
                        android:width="4.0dip"
                        android:color="#ff80ff6a" />
                    <corners
                        android:radius="16.0dip" />
                </shape>
            </item>
            <item>
                <shape
                    android:shape="rectangle">
                    <gradient
                        android:startColor="#ff0f3515"
                        android:endColor="#ff0f3515"
                        android:angle="90.0"
                        android:type="linear"
                        android:centerColor="#ff012106" />
                    <stroke
                        android:width="2.0dip"
                        android:color="#ff6ad35a" />
                    <corners
                        android:radius="16.0dip" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>