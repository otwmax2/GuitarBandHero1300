<?xml version="1.0" encoding="utf-8"?>
<ripple
    android:color="#40ffffff"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <selector>
            <item
                android:state_pressed="true">
                <shape
                    android:shape="rectangle">
                    <gradient
                        android:startColor="#ff2d0f69"
                        android:endColor="#ff2d0f69"
                        android:angle="90.0"
                        android:type="linear"
                        android:centerColor="#ff18073b" />
                    <stroke
                        android:width="4.0dip"
                        android:color="#ffb866ff" />
                    <corners
                        android:radius="16.0dip" />
                </shape>
            </item>
            <item>
                <shape
                    android:shape="rectangle">
                    <gradient
                        android:startColor="#ff200b4a"
                        android:endColor="#ff200b4a"
                        android:angle="90.0"
                        android:type="linear"
                        android:centerColor="#ff11052a" />
                    <stroke
                        android:width="2.0dip"
                        android:color="#ffa24bd6" />
                    <corners
                        android:radius="16.0dip" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>